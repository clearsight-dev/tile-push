{
  "name": "@tile-push/react-native",
  "version": "0.1.0",
  "description": "Tile Push React Native SDK — multi-tenant OTA updates for React Native apps.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "test:type": "tsc --noEmit"
  },
  "keywords": [
    "react-native",
    "ota",
    "code-push",
    "hot-updater",
    "tile-push"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@hot-updater/react-native": "*",
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@hot-updater/react-native": "workspace:*",
    "@types/react": "19.1.3",
    "react": "19.1.3",
    "react-native": "0.79.1",
    "tsdown": "catalog:tools",
    "typescript": "^6.0.2"
  }
}
